# EduQuest Environment Variables Template
# Copy this file to .env.local and fill in your values
# 
# ⚠️ SECURITY WARNING: Never commit this file with real values to version control
# This is a template file with placeholder values. Real values should be in .env.local
# which should be added to .gitignore to prevent accidental commits.

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Get these from your Supabase Dashboard -> Settings -> API
# Required for all database operations and authentication
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ⚠️ SERVER-ONLY KEY: DO NOT EXPOSE IN CLIENT CODE
# Only use this in server-side operations, backend APIs, or CLI commands
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# AUTHENTICATION CONFIGURATION  
# =============================================================================
# Site URL for authentication callbacks
# Update these values for your environment (development, staging, production)
SITE_URL=https://eduquest-admin.railway.app
AUTH_CALLBACK_URL=https://eduquest-admin.railway.app/auth/callback

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Session configuration (optional)
SESSION_TIMEOUT=3600  # Session timeout in seconds (1 hour)
JWT_SECRET=your-jwt-secret-key-here  # For session tokens (generate strong secret)

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Enable debug logging (development only)
# DEBUG=true
# LOG_LEVEL=DEBUG  # Set log level (DEBUG, INFO, WARN, ERROR)

# =============================================================================
# DATABASE CONNECTION POOLING
# =============================================================================
# Database connection settings (optional)
# MAX_CONNECTIONS=10
# CONNECTION_TIMEOUT=30

# =============================================================================
# RETRY & FAILOVER CONFIGURATION
# =============================================================================
# Retry configuration for transient failures
MAX_RETRIES=3
BASE_DELAY=2  # Initial delay between retries in seconds (exponential backoff)
RETRY_TIMEOUT=30  # Maximum timeout for retry operations in seconds

# =============================================================================
# MONITORING & METRICS
# =============================================================================
# Application monitoring (optional)
# SENTRY_DSN=your-sentry-dsn-here
# MONITORING_ENABLED=true

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================
# Development-specific settings (remove in production)
# NODE_ENV=development
# PORT=3000

# =============================================================================
# PRODUCTION ONLY (when deploying)
# =============================================================================
# Uncomment these for production deployment
# NODE_ENV=production
# PORT=8080